{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/USS-Parks/1M-Context-Sol/schemas/capability-vocabulary.schema.json",
  "title": "Context Continuum capability vocabulary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_contract",
    "dimensions",
    "public_claims",
    "limitations",
    "forbidden_public_phrases"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "model_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_slug", "fallback_allowed", "alias_allowed"],
      "properties": {
        "required_slug": { "const": "gpt-5.6-sol" },
        "fallback_allowed": { "const": false },
        "alias_allowed": { "const": false }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/dimension" }
    },
    "public_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/public_claim" }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/limitation" }
    },
    "forbidden_public_phrases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "unit",
        "definition",
        "authority",
        "gate",
        "exact_tokens",
        "minimum_tokens",
        "maximum_exclusive_tokens",
        "substitutes_for"
      ],
      "properties": {
        "id": {
          "enum": [
            "native_total_context",
            "native_max_input",
            "native_max_output",
            "codex_effective_budget",
            "operational_input_threshold",
            "durable_reservoir_capacity"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "unit": { "const": "tokens" },
        "definition": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "minLength": 1 },
        "gate": { "pattern": "^G[0-9]$" },
        "exact_tokens": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "minimum_tokens": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "maximum_exclusive_tokens": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "substitutes_for": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "public_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "required_gates",
        "enabled_before_gates_pass"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "text": { "type": "string", "minLength": 1 },
        "required_gates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "pattern": "^G[0-9]$" }
        },
        "enabled_before_gates_pass": { "const": false }
      }
    },
    "limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "text": { "type": "string", "minLength": 1 }
      }
    }
  }
}
