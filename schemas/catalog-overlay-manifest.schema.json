{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/USS-Parks/Codex-Added-Context/schemas/catalog-overlay-manifest.schema.json",
  "title": "Context Continuum catalog overlay hash manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "catalog_schema_id",
    "supported_codex_version",
    "model",
    "source_catalog_sha256",
    "source_normalized_sha256",
    "source_sol_sha256",
    "preserved_sol_sha256",
    "output_catalog_sha256",
    "output_sol_sha256",
    "output_model_count",
    "changed_policy_fields",
    "official_sol_limits",
    "overlay_policy"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "catalog_schema_id": {
      "const": "codex-model-catalog/0.144.5-v1"
    },
    "supported_codex_version": {
      "const": "0.144.5"
    },
    "model": {
      "const": "gpt-5.6-sol"
    },
    "source_catalog_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_normalized_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_sol_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "preserved_sol_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "output_catalog_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "output_sol_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "output_model_count": {
      "const": 1
    },
    "changed_policy_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "auto_compact_token_limit",
          "context_window",
          "effective_context_window_percent",
          "max_context_window"
        ]
      }
    },
    "official_sol_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "total_context_window",
        "max_input",
        "max_output"
      ],
      "properties": {
        "slug": {
          "const": "gpt-5.6-sol"
        },
        "total_context_window": {
          "minimum": 1050000,
          "type": "integer"
        },
        "max_input": {
          "minimum": 922000,
          "type": "integer"
        },
        "max_output": {
          "minimum": 128000,
          "type": "integer"
        }
      }
    },
    "overlay_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_window",
        "max_context_window",
        "effective_context_window_percent",
        "auto_compact_token_limit"
      ],
      "properties": {
        "context_window": {
          "const": 1050000
        },
        "max_context_window": {
          "const": 1050000
        },
        "effective_context_window_percent": {
          "type": "integer",
          "minimum": 96,
          "maximum": 100
        },
        "auto_compact_token_limit": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 945000
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
