{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/USS-Parks/1M-Context-Sol/schemas/sol-catalog-overlay.schema.json",
  "title": "Context Continuum GPT-5.6 Sol-only catalog overlay",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "models"
  ],
  "properties": {
    "models": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slug",
          "base_instructions",
          "model_messages",
          "context_window",
          "max_context_window",
          "effective_context_window_percent"
        ],
        "properties": {
          "slug": {
            "const": "gpt-5.6-sol"
          },
          "base_instructions": {
            "type": "string",
            "minLength": 1
          },
          "model_messages": {
            "type": [
              "object",
              "null"
            ]
          },
          "context_window": {
            "const": 1050000
          },
          "max_context_window": {
            "const": 1050000
          },
          "effective_context_window_percent": {
            "type": "integer",
            "minimum": 96,
            "maximum": 100
          },
          "auto_compact_token_limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 945000
          }
        },
        "additionalProperties": true
      }
    }
  }
}
